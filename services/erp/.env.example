# Base de datos MariaDB para Dolibarr
MYSQL_DATABASE=dolibarr
MYSQL_USER=dolibarr
MYSQL_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA
MYSQL_ROOT_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA_ROOT

# Credenciales del administrador de Dolibarr
DOLI_ADMIN_LOGIN=admin
DOLI_ADMIN_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# Instalación automática: 1 activa el init solo si no existe conf.php
# Tras el primer arranque exitoso, Dolibarr escribe conf.php en el volumen
# y este flag ya no tiene efecto (no re-ejecuta el init en reinicios)
DOLI_INSTALL_AUTO=1
