# deploy-panel — copiar a .env en el NAS, completar y NO subir al repo

WEBHOOK_SECRET=   # secreto HMAC compartido con GitHub → Settings > Webhooks
                  # generar: openssl rand -hex 32

NAS_HOST=         # IP o hostname del NAS (ej: 192.168.1.100)
NAS_USER=         # usuario SSH del NAS con permiso para ejecutar los scripts

# Las rutas siguientes usan los valores por defecto del docker-compose.yml
# Solo descomentar si cambias las rutas de montaje:
# SSH_KEY_PATH=/run/secrets/deploy_key
# SSH_KNOWN_HOSTS_PATH=/run/secrets/known_hosts
# LOG_DIR=/logs
