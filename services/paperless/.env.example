# services/paperless/.env.example
#
# Copia este fichero a `.env` (sin .example) en el NAS y rellena los valores.
# El `.env` real NO se comitea (está en .gitignore).
#
# Editar siempre con vi/nano por SSH o con un editor LF (VSCode, Notepad++).
# El Notepad de Windows mete CRLF y rompe el arranque.
# Verificar: sudo cat -A .env | grep -c '\^M'  →  debe devolver 0.
#
# Proteger el fichero tras rellenarlo:
#   sudo chmod 600 .env

# --- Identidad del usuario operador del NAS ---
# Obtener con `id -u` y `id -g` por SSH al NAS con tu usuario admin.
# Deben coincidir con el dueño de /volume1/docker/club/paperless/.
USERMAP_UID=
USERMAP_GID=

# --- Base de datos PostgreSQL ---
# Generar con: openssl rand -base64 32 | tr -d '/+=' | head -c 32
POSTGRES_PASSWORD=

# --- Clave secreta de Django ---
# Generar con: openssl rand -base64 60 | tr -d '\n'
# Mínimo 50 caracteres aleatorios.
PAPERLESS_SECRET_KEY=

# --- Superusuario `admin` auto-creado al primer arranque ---
# Paperless crea este usuario la primera vez que levanta el contenedor, leyendo
# estas tres variables. Tras el primer arranque ya vive en la BBDD y cambiarlas
# aquí no afecta a nada (salvo que borres db-data/ y vuelvas a arrancar desde
# cero, en cuyo caso se recrea con los valores actuales).
# Generar contraseña con: openssl rand -base64 24
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=
PAPERLESS_ADMIN_MAIL=sdmpedrola@dpz.es

# --- Contraseñas de referencia de los roles `junta` y `oficina` ---
# Paperless NO lee estas variables — son solo un lugar único donde guardar
# las contraseñas de los otros dos usuarios del club. La primera vez que
# entres como `admin`, ve a Settings → Users & Groups y crea los usuarios
# `junta` y `oficina` copiando estas contraseñas.
#
# Permisos (se asignan a mano al crear cada usuario desde la UI):
#   - junta   → grupo "Junta"   con permisos lectura/escritura completos
#               salvo gestión de usuarios.
#   - oficina → grupo "Oficina" con ver/subir/etiquetar documentos, SIN
#               borrar documentos ni editar corresponsales/tipos.
#
# Generar cada una con: openssl rand -base64 24
CLUB_USER_JUNTA_PASSWORD=
CLUB_USER_OFICINA_PASSWORD=
