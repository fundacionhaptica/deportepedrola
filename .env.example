NODE_ENV=production
PORT=3000

# Base de datos PostgreSQL
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgresql://deporte:CHANGEME@db:5432/deporte_pedrola

# Clave secreta para firmar los tokens JWT (pon una cadena larga y aleatoria)
JWT_SECRET=pon-aqui-una-cadena-muy-larga-y-aleatoria

# Contraseñas de los tres usuarios del panel
# Usuario "admin" → acceso total (ver, modificar, borrar)
AUTH_ADMIN_PASS=pon-aqui-la-contraseña-del-admin

# Usuario "junta" → puede ver y modificar, pero no borrar
AUTH_JUNTA_PASS=pon-aqui-la-contraseña-de-junta

# Usuario "socio" → solo puede ver
AUTH_SOCIO_PASS=pon-aqui-la-contraseña-de-socio

# Kimi (OCR de facturas con visión IA - opcional, no funciona bien con escaneados)
MOONSHOT_API_KEY=

# Gemini (OCR fallback - opcional, calidad variable)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# vision-router del NAS (OCR propio del usuario en proyecto-ia, en red ia-net)
# Requiere ANTHROPIC_API_KEY en proyecto-ia/.env para que /facturas funcione.
# Hoy no se usa: el flujo OCR es manual asistido por Cowork (ver docs/WORKFLOW_OCR_COWORK.md).
VISION_INTERNAL_API_KEY=
OCR_API_URL=http://vision-router:8003

# Clave compartida para que scripts internos (p.ej. subir_documento.py) puedan llamar
# a /api/facturas/upload sin JWT de usuario. Generar con: openssl rand -hex 32
INTERNAL_API_KEY=

# Stripe (pagos)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# URL pública de la aplicación (para Stripe callbacks)
PUBLIC_URL=https://erp.deportepedrola.com

# Datos del club (para certificados de donación y correos)
CLUB_NOMBRE=Club Deportivo Elemental Deporte Pedrola
CLUB_CIF=G99528549
CLUB_DIRECCION=Calle Acceso Piscina s/n, 50690 Pedrola, Zaragoza
CLUB_CP=50690
CLUB_EMAIL=hola@deportepedrola.com
CLUB_TELEFONO=
CLUB_REPRESENTANTE_NOMBRE=Jaime Ruiz
CLUB_REPRESENTANTE_DNI=
CLUB_REPRESENTANTE_CARGO=Presidente

# Directorio de uploads dentro del contenedor
UPLOADS_DIR=/app/uploads

# ===========================================================================
# Envío de email (avisos de previsión de cuota, certificados, etc.) - SMTP
# ===========================================================================
#
# El club usa Zoho Mail EU (https://mail.zoho.eu) con la cuenta hola@deportepedrola.com.
#
# IMPORTANTE: SMTP_PASS debe ser una "App-Specific Password" generada en Zoho:
#   1. Inicia sesión en https://mail.zoho.eu
#   2. Click en tu inicial (arriba derecha) -> My Account -> Security
#   3. Sección App Passwords -> Generate New Password
#   4. Nombre: "deportepedrola-erp" (o el que quieras)
#   5. Copia el password generado (16 caracteres) y pégalo en SMTP_PASS
#
# Alternativas si cambias de proveedor:
#   - Gmail/Workspace: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
#   - Microsoft 365:   SMTP_HOST=smtp.office365.com, SMTP_PORT=587, SMTP_SECURE=false
#
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hola@deportepedrola.com
SMTP_PASS=
# Remitente visible (formato: "Nombre <correo@dominio>" o solo "correo@dominio")
SMTP_FROM=CDE Deporte Pedrola <hola@deportepedrola.com>
# Copia oculta opcional (por ejemplo, el correo del tesorero); dejar vacío si no se usa
SMTP_BCC=