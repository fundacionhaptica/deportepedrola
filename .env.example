# .env.example — raíz del repo
#
# Copia a `.env` en la raíz del repo en el NAS y rellena todos los valores.
# El `.env` real NO se comitea (está en .gitignore).
#
# Generar contraseñas:   openssl rand -base64 32 | tr -d '/+=' | head -c 32
# Generar secret key:    openssl rand -base64 60 | tr -d '\n'
#
# ADEMÁS de este .env, dos servicios necesitan su propio .env en su carpeta:
#   · services/deploy-panel/.env  (ver services/deploy-panel/.env.example)
#   · services/ocr-facturas/.env  (ver services/ocr-facturas/.env.example)
#
# Proteger tras rellenar:   chmod 600 .env

# ── NAS – usuario operador ────────────────────────────────────────────────
# Obtener con `id -u` y `id -g` por SSH con el usuario admin del NAS.
USERMAP_UID=
USERMAP_GID=

# ── ERP – Dolibarr ───────────────────────────────────────────────────────
ERP_POSTGRES_DB=dolibarr
ERP_POSTGRES_USER=dolibarr
ERP_POSTGRES_PASSWORD=

ERP_DOLI_ADMIN_LOGIN=admin
ERP_DOLI_ADMIN_PASSWORD=

# ── Paperless-ngx ────────────────────────────────────────────────────────
# Contraseña de la base de datos interna de Paperless
PAPERLESS_POSTGRES_PASSWORD=

# Clave secreta de Django (mínimo 50 caracteres)
PAPERLESS_SECRET_KEY=

# Superusuario admin (solo se usa en el primer arranque)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=
PAPERLESS_ADMIN_MAIL=sdmpedrola@dpz.es

# Contraseñas de referencia de los roles junta y oficina
# (Paperless no las lee; son solo un sitio único donde guardarlas)
CLUB_USER_JUNTA_PASSWORD=
CLUB_USER_OFICINA_PASSWORD=

# ── paperless-ai – Kimi (Moonshot AI) ────────────────────────────────────
# Token de API de Paperless (obtener en la UI: Settings → API Tokens,
# crear token para el usuario `admin` tras el primer arranque)
PAPERLESS_API_TOKEN=

# API Key de Kimi — https://platform.moonshot.cn
KIMI_API_KEY=

# Modelo: kimi-k2-0520 (recomendado) | moonshot-v1-32k | moonshot-v1-8k
KIMI_MODEL=kimi-k2-0520
