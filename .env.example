NODE_ENV=production
PORT=3000

# Base de datos PostgreSQL
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgresql://deporte:CHANGEME@db:5432/deporte_pedrola

# Clave secreta para firmar los tokens JWT (pon una cadena larga y aleatoria)
JWT_SECRET=pon-aqui-una-cadena-muy-larga-y-aleatoria

# Contraseñas de los tres usuarios del panel
# Usuario "admin" → acceso total (ver, modificar, borrar)
AUTH_ADMIN_PASS=pon-aqui-la-contraseña-del-admin

# Usuario "junta" → puede ver y modificar, pero no borrar
AUTH_JUNTA_PASS=pon-aqui-la-contraseña-de-junta

# Usuario "socio" → solo puede ver
AUTH_SOCIO_PASS=pon-aqui-la-contraseña-de-socio

# Kimi (OCR de facturas con visión IA)
MOONSHOT_API_KEY=

# Stripe (pagos)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# URL pública de la aplicación (para Stripe callbacks)
PUBLIC_URL=https://erp.deportepedrola.com

# Datos del club (para certificados de donación)
CLUB_NOMBRE=Club Deportivo Elemental Deporte Pedrola
CLUB_CIF=G99528549
CLUB_DIRECCION=Calle Acceso Piscina s/n, 50690 Pedrola, Zaragoza
CLUB_CP=50690
CLUB_EMAIL=
CLUB_TELEFONO=
CLUB_REPRESENTANTE_NOMBRE=Jaime Ruiz
CLUB_REPRESENTANTE_DNI=
CLUB_REPRESENTANTE_CARGO=Presidente

# Directorio de uploads dentro del contenedor
UPLOADS_DIR=/app/uploads
