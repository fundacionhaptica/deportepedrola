# ── Dependencias ──────────────────────────────────────────────
node_modules/

# ── Variables de entorno y secretos ───────────────────────────
# Importante: cualquier *.env incluye apis.env, .env.local, etc.
*.env
!.env.example
.deploy/
.ssh/

# ── Datos / volumenes (solo en NAS, nunca en git) ─────────────
uploads/*
!uploads/.gitkeep
documentos/
ibercaja/justificantes/
ibercaja/pendientes/
ibercaja/__pycache__/

# ── Ficheros y backups de la carpeta scripts/ ─────────────────
# Los PDFs, Excel y CSVs nunca van a git (estan en el NAS).
scripts/*.pdf
scripts/*.xlsx
scripts/*.xlsx.bak-*
scripts/*.csv
scripts/*.txt

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── Caches Python ─────────────────────────────────────────────
__pycache__/
*.pyc

# ── Imagenes locales del frontend (subir manualmente) ─────────
public/firma.png
public/logo.png

# ── Metadatos del NAS Synology ────────────────────────────────
@eaDir/
Thumbs.db
.DS_Store

# ── Carpetas temporales ───────────────────────────────────────
tmp/
.claude/
.cache/
# ── Backups con sufijo de fecha (cualquier archivo *.bak-YYYYMMDD) ────
Movimientos_caja.bak-*
*.bak-*
